DATABASE_URL=postgresql+asyncpg://taskhive:taskhive@localhost:5432/taskhive
NEXTAUTH_SECRET=your-secret-for-jwt-signing
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Orchestrator (main.py) settings
# Directory where agent workspaces are written/read
AGENT_WORKSPACE_DIR=/opt/taskhive/agent_works
# URL of the Next.js frontend (used for CORS)
NEXT_APP_URL=http://localhost:3000
# Additional comma-separated CORS origins (e.g. https://yourdomain.com)
EXTRA_CORS_ORIGINS=

# Orchestrator
TASKHIVE_API_BASE_URL=http://localhost:3000/api/v1
# TASKHIVE_API_KEY: the API key for the TaskHive Orchestrator agent (seeded by scripts/seed_agents.py)
TASKHIVE_API_KEY=th_agent_4cbd9fbde50424cedc203c7f48958c8138949cab5d7d3a181cfde35dc08f71d2

# System agent API keys (seeded by scripts/seed_agents.py or auto-seeded on first startup)
REVIEWER_AGENT_API_KEY=th_agent_baf0a258db6095f68ab514cb16dd29927c5dfa606953916346e2c34fb08700a2
CODING_AGENT_API_KEY=th_agent_e31c9d408361ab222c5668af6c48fc0484300759ffa350942e58df0111069b94
WRITING_AGENT_API_KEY=th_agent_23cf36e629f4d547433084db564f9e075ab23937d1f71d08210dbf6ffb5adf76
RESEARCH_AGENT_API_KEY=th_agent_d927bcc2f0ce4e9e43fe930dbc348c23062a9debeb9bdf19c7d056bed0c972ae
DATA_AGENT_API_KEY=th_agent_d43b6c659879a9f161475bfa321fd82e0d23331b272fa2a7432ef5ee5220e8ac

# LLM Providers
OPENROUTER_API_KEY=sk-or-v1-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
MOONSHOT_API_KEY=sk-your-moonshot-key-here

# Model tiers (format: provider/model-id)
# fast    = cheap/free for triage & clarification
# default = mid-tier for planning & execution
# strong  = best quality for complex tasks & review
# thinking = deep reasoning with chain-of-thought
FAST_MODEL=openrouter/arcee-ai/trinity-large-preview:free
DEFAULT_MODEL=openrouter/stepfun/step-3.5-flash:free
STRONG_MODEL=anthropic/claude-opus-4-5-20250514
THINKING_MODEL=moonshot/kimi-k2-thinking

# Frontend coding pipeline models
# These are used when triage identifies the task as task_type="frontend"
#
#   CODING_MODEL         primary execution model (z-ai/glm-5, prioritized)
#   CODING_STRONG_MODEL  escalated for complexity==high or budget>500 (gpt-5.3-codex)
#   CODING_PLANNING_MODEL strong thinking model for the planning stage (claude-sonnet-4.6)
#   CODING_ALT_MODEL_1/2 intermediate fallbacks in the CODING tier chain
#
# Full fallback chain for execution:
#   z-ai/glm-5 → minimax-m2.5 → gemini-3-flash-preview → gpt-5.3-codex → DEFAULT
CODING_MODEL=openrouter/z-ai/glm-5
CODING_STRONG_MODEL=openrouter/openai/gpt-5.3-codex
CODING_PLANNING_MODEL=anthropic/claude-sonnet-4.6
CODING_ALT_MODEL_1=openrouter/minimax/minimax-m2.5
CODING_ALT_MODEL_2=openrouter/google/gemini-3-flash-preview

# Deployment pipeline (MANDATORY — all tasks are deployed)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_ORG=your-github-org-or-username
GITHUB_REPO_PREFIX=taskhive-agent
GITHUB_BRANCH=main

# Vercel deployment (preferred: CLI via token, fallback: custom endpoint)
VERCEL_TOKEN=vcp_your_vercel_token_here
VERCEL_ORG_ID=team_your_vercel_org_id_here
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_DEPLOY_ENDPOINT=


MAX_CONCURRENT_TASKS=5
TASK_POLL_INTERVAL=30
SANDBOX_TIMEOUT=120
WORKSPACE_ROOT=/tmp/taskhive-workspaces
ALLOWED_COMMANDS=python,node,npm,npx,pip,git,ls,cat,head,tail,grep,find,mkdir,cp,mv,rm,touch,echo,curl,wget,tsc,eslint,flake8,pytest,make,sh,bash,cd,pwd,which,env,sort,uniq,wc,tr,cut,sed,awk,diff,patch,tar,gzip,unzip,ssh-keygen,openssl,jq,xargs
BLOCKED_PATTERNS=sudo,su ,chmod 777,rm -rf /,> /etc,> /dev

#uv sync; uv run uvicorn app.main:app --reload --port 8000
