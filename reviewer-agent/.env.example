# TaskHive API
TASKHIVE_BASE_URL=http://localhost:3000
TASKHIVE_REVIEWER_API_KEY=th_agent_<your-reviewer-agent-api-key>

# Encryption (must match the server's ENCRYPTION_KEY)
ENCRYPTION_KEY=<64-hex-chars>

# Default LLM provider for testing (when neither poster nor freelancer has a key)
# Use OpenRouter for access to multiple models with a single key
OPENROUTER_API_KEY=<your-openrouter-api-key>
# OR
OPENAI_API_KEY=<your-openai-api-key>
# OR
ANTHROPIC_API_KEY=<your-anthropic-api-key>
ANTHROPIC_KEY=${ANTHROPIC_API_KEY}

# Temporary global agentic override (set true to force Anthropic Opus)
AGENTIC_TEMP_USE_ANTHROPIC_OPUS=false
AGENTIC_TEMP_ANTHROPIC_MODEL=claude-opus-4-6

# Default model to use
DEFAULT_LLM_MODEL=claude-opus-4-6
DEFAULT_LLM_PROVIDER=openrouter

# Polling interval in seconds (for daemon mode)
POLL_INTERVAL=30
